.DS_Store

# macOS / editor noise
.idea/
.vscode/

# Jekyll build artifacts
docs/_site/
docs/.jekyll-cache/
docs/.sass-cache/
docs/Gemfile.lock

# Playwright MCP scratch
.playwright-mcp/

