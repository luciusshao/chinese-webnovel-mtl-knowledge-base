# Copy this file to scripts/.env and fill in real values.
# scripts/.env is gitignored — never commit your real credentials.

# The Google Sheet that the form responses land in.
# Find the ID inside the URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=

# The tab inside the Sheet that contains the responses.
# Google Forms creates a tab called "Form Responses 1" by default.
# Override here if you renamed it.
SHEET_TAB=Form Responses 1

# Absolute path to the Service Account JSON key file.
# Recommended location: ~/.config/glossary-sync/service-account.json
# Make sure: chmod 600 <path>  and  share the Sheet with the SA's client_email.
SA_KEY_PATH=
